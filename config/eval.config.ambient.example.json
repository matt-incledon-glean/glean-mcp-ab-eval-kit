{
  "eval_name": "customer-glean-mcp-ab-eval",
  "mcp_mode": "ambient",
  "prompts_file": "golden_prompts.tsv",
  "results_dir": "results",
  "model": "opus",
  "judge_model": "opus",
  "judge_mcp_config": "config/mcp.none.json",
  "judge_hide_tokens": false,
  "max_turns": 20,
  "default_disallow_builtin_tools": true,
  "require_preflight_before_run": true,
  "require_live_preflight_before_run": true,
  "prompt_wrapper": "Answer the following enterprise knowledge question. This task is STRICTLY READ-ONLY: use only search and read tools to find current, grounded sources. Never create, edit, comment on, transition, delete, or otherwise modify any content, and never use a write action as a workaround to reach data. Cite source names/URLs when available. If you cannot find enough evidence, say what is missing.\n\nQuestion:\n{prompt}",
  "preflight_timeout_seconds": 300,
  "run_timeout_seconds": 1800,
  "pricing_per_million": {
    "input_tokens": 5.0,
    "output_tokens": 25.0,
    "cache_creation_input_tokens": 6.25,
    "cache_read_input_tokens": 0.5
  },
  "arms": {
    "glean": {
      "label": "Glean MCP",
      "expected_mcp_servers": ["glean_default"],
      "forbidden_mcp_servers": ["atlassian", "slack", "jira", "confluence", "github", "notion", "google_drive", "gmail", "outlook", "zoom"],
      "allowed_tools": ["mcp__glean_default__search", "mcp__glean_default__read_document", "mcp__glean_default__chat", "mcp__glean_default__employee_search"],
      "disallowed_tools": ["mcp__glean_default__run_tool", "mcp__glean_default__find_skills", "mcp__glean_default__read_skill_files"],
      "preflight_prompt": "Use the Glean MCP tools to perform a harmless read-only search for a known internal page and return a one-sentence confirmation that retrieval worked."
    },
    "direct": {
      "label": "Atlassian + Slack (direct)",
      "expected_mcp_servers": ["atlassian", "slack"],
      "forbidden_mcp_servers": ["glean_default", "glean"],
      "allowed_tools": [
        "mcp__atlassian__search",
        "mcp__atlassian__getAccessibleAtlassianResources",
        "mcp__atlassian__getJiraIssue",
        "mcp__atlassian__getConfluencePage",
        "mcp__atlassian__searchJiraIssuesUsingJql",
        "mcp__slack__slack_search_public",
        "mcp__slack__slack_search_public_and_private",
        "mcp__slack__slack_search_channels",
        "mcp__slack__slack_read_channel",
        "mcp__slack__slack_read_thread",
        "mcp__slack__slack_read_user_profile"
      ],
      "disallowed_tools": [
        "mcp__atlassian__addCommentToJiraIssue",
        "mcp__atlassian__editJiraIssue",
        "mcp__atlassian__createJiraIssue",
        "mcp__atlassian__transitionJiraIssue",
        "mcp__slack__slack_send_message",
        "mcp__slack__slack_schedule_message",
        "mcp__slack__slack_send_message_draft"
      ],
      "preflight_prompt": "Use Atlassian MCP to perform a harmless read-only lookup, then use Slack MCP to perform a harmless read-only search. Return one sentence confirming both retrievals worked."
    }
  }
}
